# Copy to .env (untracked) for local overrides.
# Both Angular and Playwright read these via process.env.

# Docker local stack (API container published as localhost:3000, panel on :4000):
#   docker compose -f docker-compose.local.yml up --build
PORT=4000

# Playwright E2E credentials. Leave unset to use the demo account
# baked into the mock AuthService (useful while useMockAuth=true).
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
